    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "fabric": "^6.0.0-rc4",
    "ffmpeg-static": "^5.2.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.5.0",
    "fluent-ffmpeg": "^2.1.2",
